<div id="zourcefy-group-buy-container" class="zourcefy-widget-hidden" data-product-id="{{ product.id }}">
  <div class="zourcefy-card">
    
    <!-- ACTIVE POOL CONTAINER -->
    <div id="zourcefy-active-state" class="zourcefy-hidden">
      <!-- Header -->
      <div class="zourcefy-header">
        <div class="zourcefy-badge-wrapper">
          <span class="zourcefy-badge">Active Group Buy</span>
        </div>
        <div id="zourcefy-discount-tag" class="zourcefy-discount-tag">Unlocks --% Off</div>
      </div>

      <!-- Product Title -->
      <h3 id="zourcefy-product-title" class="zourcefy-title">Loading procurement pool...</h3>

      <!-- Stats & Progress -->
      <div class="zourcefy-stats">
        <div class="zourcefy-stat-item">
          <span class="zourcefy-label">Current Volume</span>
          <strong id="zourcefy-current-qty">0 Units</strong>
        </div>
        <div class="zourcefy-stat-item">
          <span class="zourcefy-label">Target Volume</span>
          <strong id="zourcefy-target-qty">0 Units</strong>
        </div>
      </div>

      <div class="zourcefy-progress-container">
        <div id="zourcefy-progress-bar" class="zourcefy-progress-bar" style="width: 0%;"></div>
      </div>

      <!-- Multi-tier Breakdown -->
      <div id="zourcefy-tiers-wrapper" class="zourcefy-tiers-wrapper zourcefy-hidden">
        <span class="zourcefy-label">Discount Tiers</span>
        <div id="zourcefy-tiers-list" class="zourcefy-tiers-list"></div>
      </div>

      <div class="zourcefy-meta-info" style="margin-top: 12px;">
        <span id="zourcefy-member-count" class="zourcefy-members">0 participants joined</span>
        <span id="zourcefy-status-text" class="zourcefy-status-text">--% reached</span>
      </div>

      <!-- Interactive CTA Area -->
      <div id="zourcefy-cta-area" class="zourcefy-cta-area">
        <form id="zourcefy-join-form" class="zourcefy-form">
          <input type="hidden" name="productId" value="{{ product.id }}">
          
          {% if customer %}
            <input type="hidden" name="customerId" value="{{ customer.id }}">
            <input type="hidden" name="customerEmail" value="{{ customer.email }}">
          {% else %}
            <input type="hidden" name="customerId" id="zourcefy-join-customer-id" value="">
            <div class="zourcefy-input-group">
              <label for="zourcefy-join-email" class="zourcefy-input-label">Your Email Address:</label>
              <input 
                id="zourcefy-join-email" 
                type="email" 
                name="customerEmail" 
                placeholder="you@company.com" 
                required 
                class="zourcefy-input"
              >
            </div>
          {% endif %}
          
          <div class="zourcefy-input-group">
            <label for="zourcefy-qty-input" class="zourcefy-input-label">Volume to Commit:</label>
            <div class="zourcefy-qty-wrapper">
              <input 
                id="zourcefy-qty-input" 
                type="number" 
                name="quantity" 
                min="0.1" 
                step="0.1" 
                value="1" 
                required 
                class="zourcefy-input"
              >
              <span class="zourcefy-qty-unit">Units</span>
            </div>
          </div>

          <button id="zourcefy-submit-btn" type="submit" class="zourcefy-btn">
            <span class="btn-text">Join Procurement Pool</span>
            <span class="btn-loader zourcefy-hidden"></span>
          </button>
        </form>
      </div>
    </div>

    <!-- CREATOR PENDING CONTAINER (Visible only to creator while pending approval) -->
    <div id="zourcefy-pending-state" class="zourcefy-hidden">
      <div class="zourcefy-header">
        <div class="zourcefy-badge-wrapper">
          <span class="zourcefy-badge" style="border-color: #f59e0b; color: #f59e0b; box-shadow: 0 0 10px rgba(245, 158, 11, 0.4);">Pending Approval</span>
        </div>
      </div>
      <h3 class="zourcefy-title">Your Pool Request is Under Review</h3>
      <p style="color: var(--zourcefy-text-secondary); font-size: 14px; margin-top: -8px; margin-bottom: 16px; line-height: 1.5;">
        Your group buy pool request for this product has been submitted. The store owner is setting custom volume discount tiers and will activate it shortly!
      </p>
      <div id="zourcefy-pending-details" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 12px 16px; font-size: 13px; color: var(--zourcefy-text-secondary);">
        Status: <strong style="color: #f59e0b;">Awaiting Admin Approval</strong>
      </div>
    </div>

    <!-- CREATE POOL CONTAINER (Visible to everyone when no pool exists) -->
    <div id="zourcefy-create-state" class="zourcefy-hidden">
      <div class="zourcefy-header">
        <div class="zourcefy-badge-wrapper">
          <span class="zourcefy-badge" style="border-color: #f59e0b; color: #f59e0b; box-shadow: 0 0 10px rgba(245, 158, 11, 0.4);">Group Buy Available</span>
        </div>
      </div>

      <h3 class="zourcefy-title">Start a Group Buy Pool</h3>
      <p style="color: var(--zourcefy-text-secondary); font-size: 14px; margin-top: -10px; margin-bottom: 20px;">
        Be the first to commit volume for this product and request custom wholesale volume discounts!
      </p>

      <a 
        id="zourcefy-create-redirect-btn" 
        href="/apps/zourcefy-pool/create?productId={{ product.id }}&productTitle={{ product.title | url_encode }}&productHandle={{ product.handle }}" 
        class="zourcefy-btn" 
        style="text-decoration: none; text-align: center; background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); box-shadow: 0 4px 14px rgba(245, 158, 11, 0.3);"
      >
        Request Group Buy
      </a>
    </div>

    <!-- Message Alerts -->
    <div id="zourcefy-message-box" class="zourcefy-message-box zourcefy-hidden"></div>
  </div>
</div>

<style>
  :root {
    --zourcefy-bg: rgba(15, 23, 42, 0.95);
    --zourcefy-border: rgba(255, 255, 255, 0.1);
    --zourcefy-text-primary: #f8fafc;
    --zourcefy-text-secondary: #94a3b8;
    --zourcefy-accent: #06b6d4;
    --zourcefy-accent-glow: rgba(6, 182, 212, 0.4);
    --zourcefy-success: #10b981;
    --zourcefy-error: #ef4444;
  }

  .zourcefy-widget-hidden {
    display: none !important;
  }

  .zourcefy-hidden {
    display: none !important;
  }

  #zourcefy-group-buy-container {
    margin: 24px 0;
    max-width: 100%;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  .zourcefy-card {
    background: var(--zourcefy-bg);
    border: 1px solid var(--zourcefy-border);
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(8px);
    color: var(--zourcefy-text-primary);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .zourcefy-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .zourcefy-badge {
    background: rgba(6, 182, 212, 0.15);
    border: 1px solid var(--zourcefy-accent);
    color: var(--zourcefy-accent);
    padding: 4px 10px;
    border-radius: 9999px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    box-shadow: 0 0 10px var(--zourcefy-accent-glow);
  }

  .zourcefy-discount-tag {
    font-size: 14px;
    font-weight: 700;
    color: #38bdf8;
    background: rgba(56, 189, 248, 0.1);
    padding: 4px 10px;
    border-radius: 6px;
  }

  .zourcefy-title {
    font-size: 20px;
    font-weight: 700;
    margin: 0 0 16px 0;
    letter-spacing: -0.02em;
    color: var(--zourcefy-text-primary);
  }

  .zourcefy-stats {
    display: flex;
    gap: 24px;
    margin-bottom: 16px;
  }

  .zourcefy-stat-item {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .zourcefy-label {
    font-size: 12px;
    color: var(--zourcefy-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 4px;
  }

  .zourcefy-stat-item strong {
    font-size: 18px;
    font-weight: 700;
  }

  .zourcefy-progress-container {
    height: 8px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 9999px;
    overflow: hidden;
    margin-bottom: 10px;
    position: relative;
  }

  .zourcefy-progress-bar {
    height: 100%;
    background: linear-gradient(90deg, #06b6d4 0%, #3b82f6 100%);
    border-radius: 9999px;
    transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 0 8px var(--zourcefy-accent-glow);
  }

  .zourcefy-tiers-wrapper {
    margin-top: 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .zourcefy-tiers-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .zourcefy-tier-chip {
    padding: 4px 10px;
    border-radius: 6px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    font-size: 12px;
    color: var(--zourcefy-text-secondary);
  }

  .zourcefy-tier-chip.unlocked {
    background: rgba(16, 185, 129, 0.15);
    border-color: #10b981;
    color: #10b981;
    font-weight: 600;
  }

  .zourcefy-meta-info {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    color: var(--zourcefy-text-secondary);
    margin-bottom: 24px;
  }

  .zourcefy-cta-area {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 20px;
  }

  .zourcefy-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .zourcefy-input-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .zourcefy-input-label {
    font-size: 13px;
    color: var(--zourcefy-text-secondary);
  }

  .zourcefy-qty-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .zourcefy-input {
    width: 100%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: var(--zourcefy-text-primary);
    padding: 12px 60px 12px 16px;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .zourcefy-qty-unit {
    position: absolute;
    right: 16px;
    color: var(--zourcefy-text-secondary);
    font-size: 14px;
    pointer-events: none;
    font-weight: 500;
  }

  .zourcefy-btn {
    background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%);
    color: #ffffff;
    border: none;
    padding: 14px 24px;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    justify-content: center;
    align-items: center;
    box-shadow: 0 4px 14px rgba(6, 182, 212, 0.3);
  }

  .zourcefy-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(6, 182, 212, 0.4);
    background: linear-gradient(135deg, #0891b2 0%, #0e7490 100%);
  }

  .zourcefy-message-box {
    margin-top: 16px;
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 14px;
    line-height: 1.4;
  }

  .zourcefy-message-box.success {
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid var(--zourcefy-success);
    color: var(--zourcefy-success);
  }

  .zourcefy-message-box.error {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid var(--zourcefy-error);
    color: var(--zourcefy-error);
  }

  .btn-loader {
    width: 20px;
    height: 20px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    border-top-color: white;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const container = document.getElementById('zourcefy-group-buy-container');
    if (!container) return;

    const productId = container.getAttribute('data-product-id');
    if (!productId) return;

    const activeStateEl = document.getElementById('zourcefy-active-state');
    const pendingStateEl = document.getElementById('zourcefy-pending-state');
    const createStateEl = document.getElementById('zourcefy-create-state');
    
    const titleEl = document.getElementById('zourcefy-product-title');
    const discountEl = document.getElementById('zourcefy-discount-tag');
    const currentQtyEl = document.getElementById('zourcefy-current-qty');
    const targetQtyEl = document.getElementById('zourcefy-target-qty');
    const progressBarEl = document.getElementById('zourcefy-progress-bar');
    const memberCountEl = document.getElementById('zourcefy-member-count');
    const statusTextEl = document.getElementById('zourcefy-status-text');
    const tiersWrapperEl = document.getElementById('zourcefy-tiers-wrapper');
    const tiersListEl = document.getElementById('zourcefy-tiers-list');
    
    const ctaAreaEl = document.getElementById('zourcefy-cta-area');
    const formEl = document.getElementById('zourcefy-join-form');
    const submitBtnEl = document.getElementById('zourcefy-submit-btn');
    const messageBoxEl = document.getElementById('zourcefy-message-box');

    // Customer details context
    let customerEmail = "{% if customer %}{{ customer.email }}{% endif %}";
    let customerId = "{% if customer %}{{ customer.id }}{% endif %}";

    if (!customerEmail) {
      customerEmail = localStorage.getItem('zourcefy_guest_email') || '';
    }

    const joinCustIdEl = document.getElementById('zourcefy-join-customer-id');
    if (joinCustIdEl && !customerId) {
      joinCustIdEl.value = 'guest_' + Math.random().toString(36).substring(2, 15);
    }

    // Build URL params
    const queryParams = new URLSearchParams({ productId: productId });
    if (customerEmail) queryParams.append('customerEmail', customerEmail);
    if (customerId) queryParams.append('customerId', customerId);

    fetch(`/apps/zourcefy-pool?${queryParams.toString()}`)
      .then(response => response.json())
      .then(data => {
        container.classList.remove('zourcefy-widget-hidden');

        // Check Creator-Pending State
        if (data.isCreatorPending && data.pendingPool) {
          activeStateEl.classList.add('zourcefy-hidden');
          createStateEl.classList.add('zourcefy-hidden');
          pendingStateEl.classList.remove('zourcefy-hidden');
          return;
        }

        // Check if Active Pool Exists
        if (!data || !data.hasActivePool || !data.pool) {
          activeStateEl.classList.add('zourcefy-hidden');
          pendingStateEl.classList.add('zourcefy-hidden');
          createStateEl.classList.remove('zourcefy-hidden');
          return;
        }

        const pool = data.pool;

        // Show active state
        activeStateEl.classList.remove('zourcefy-hidden');
        pendingStateEl.classList.add('zourcefy-hidden');
        createStateEl.classList.add('zourcefy-hidden');

        titleEl.textContent = pool.productTitle;
        discountEl.textContent = `Unlocks ${pool.discountPercent}% Off`;
        currentQtyEl.textContent = `${pool.currentQuantity} Units`;
        targetQtyEl.textContent = `${pool.targetQuantity} Units`;
        memberCountEl.textContent = `${pool.memberCount} ${pool.memberCount === 1 ? 'participant' : 'participants'} joined`;

        const progressPercent = Math.min(100, Math.round((pool.currentQuantity / pool.targetQuantity) * 100));
        progressBarEl.style.width = `${progressPercent}%`;
        statusTextEl.textContent = `${progressPercent}% reached`;

        // Render tiers if available
        if (pool.tiers && pool.tiers.length > 0) {
          tiersWrapperEl.classList.remove('zourcefy-hidden');
          tiersListEl.innerHTML = pool.tiers.map(t => {
            const isUnlocked = pool.currentQuantity >= t.targetQuantity;
            return `<div class="zourcefy-tier-chip ${isUnlocked ? 'unlocked' : ''}">
              ${t.targetQuantity} Units: <strong>${t.discountPercent}% OFF</strong> ${isUnlocked ? '✓' : ''}
            </div>`;
          }).join('');
        }

        if (pool.status === 'COMPLETED') {
          ctaAreaEl.innerHTML = `
            <div class="zourcefy-message-box success" style="margin-top: 0;">
              <strong>🎯 Pool Completed!</strong> The target of ${pool.targetQuantity} Units has been reached. The wholesale discount is unlocked!
            </div>
          `;
        }
      })
      .catch(err => {
        console.error('Error fetching group buy pool:', err);
      });

    // Form submission handler
    if (formEl) {
      formEl.addEventListener('submit', function(e) {
        e.preventDefault();

        const btnText = submitBtnEl.querySelector('.btn-text');
        const btnLoader = submitBtnEl.querySelector('.btn-loader');

        submitBtnEl.disabled = true;
        btnText.classList.add('zourcefy-hidden');
        btnLoader.classList.remove('zourcefy-hidden');

        messageBoxEl.className = 'zourcefy-message-box zourcefy-hidden';

        const formData = new FormData(formEl);
        const payload = {
          productId: formData.get('productId'),
          customerId: formData.get('customerId'),
          customerEmail: formData.get('customerEmail'),
          quantity: parseFloat(formData.get('quantity'))
        };

        if (payload.customerEmail) {
          localStorage.setItem('zourcefy_guest_email', payload.customerEmail);
        }

        fetch('/apps/zourcefy-pool', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        })
        .then(res => res.json())
        .then(data => {
          submitBtnEl.disabled = false;
          btnText.classList.remove('zourcefy-hidden');
          btnLoader.classList.add('zourcefy-hidden');

          if (data.error) {
            messageBoxEl.className = 'zourcefy-message-box error';
            messageBoxEl.textContent = data.error;
          } else if (data.success) {
            messageBoxEl.className = 'zourcefy-message-box success';
            messageBoxEl.innerHTML = `<strong>🎉 Joined Pool!</strong> Successfully committed ${payload.quantity} Units.`;
            setTimeout(() => { window.location.reload(); }, 1800);
          }
        })
        .catch(err => {
          submitBtnEl.disabled = false;
          btnText.classList.remove('zourcefy-hidden');
          btnLoader.classList.add('zourcefy-hidden');
          messageBoxEl.className = 'zourcefy-message-box error';
          messageBoxEl.textContent = 'An unexpected error occurred.';
        });
      });
    }
  });
</script>

{% schema %}
{
  "name": "Group Buy Pool",
  "target": "section",
  "settings": []
}
{% endschema %}
