PORT=3000
MONGODB_URI=your-mongodb-connection-string
DEFAULT_TARGET_QUANTITY=100

# Shopify Credentials (get these from Shopify Partners dashboard)
SHOPIFY_API_KEY=your-client-id
SHOPIFY_API_SECRET=your-client-secret
SCOPES=write_products,write_metaobjects,write_metaobject_definitions
SHOPIFY_APP_URL=your-production-app-url

# Database Connection
DATABASE_URL="file:dev.sqlite"
